[
  {
    "id": "fr-001",
    "text": "L'Éternel est mon berger: je ne manquerai de rien.",
    "ref": "Psaumes 23:1",
    "tags": ["paix", "confiance"]
  },
  {
    "id": "fr-002",
    "text": "Ne crains rien, car je suis avec toi.",
    "ref": "Ésaïe 41:10",
    "tags": ["encouragement", "force"]
  },
  {
    "id": "fr-003",
    "text": "Or la foi est une ferme assurance des choses qu'on espère.",
    "ref": "Hébreux 11:1",
    "tags": ["foi"]
  },
  {
    "id": "fr-004",
    "text": "Venez à moi, vous tous qui êtes fatigués et chargés.",
    "ref": "Matthieu 11:28",
    "tags": ["encouragement", "paix"]
  },
  {
    "id": "fr-005",
    "text": "Ne vous inquiétez donc pas du lendemain; car le lendemain aura soin de lui-même.",
    "ref": "Matthieu 6:34",
    "tags": ["encouragement", "paix"]
  },
  {
    "id": "fr-006",
    "text": "Combien acquérir la sagesse vaut mieux que l'or fin! Combien acquérir l'intelligence est préférable à l'argent!",
    "ref": "Proverbes 16:16",
    "tags": ["sagesse", "connaissance"]
  },
  {
    "id": "fr-007",
    "text": "L'Éternel sera toujours ton guide, il rassasiera ton âme dans les lieux arides...",
    "ref": "Ésaïe 58:11",
    "tags": ["encouragement", "force"]
  },
  {
    "id": "fr-008",
    "text": "Soyez toujours joyeux.",
    "ref": "1 Thessaloniciens 5:16",
    "tags": ["joie", "encouragement"]
  },
  {
    "id": "fr-009",
    "text": "Car rien n'est impossible à Dieu.",
    "ref": "Luc 1:37",
    "tags": ["encouragement"]
  },
  {
    "id": "fr-010",
    "text": "Dieu est amour.",
    "ref": "1 Jean 4:16",
    "tags": ["amour", "confiance"]
  },
  {
    "id": "fr-011",
    "text": "Je puis tout par celui qui me fortifie.",
    "ref": "Philippiens 4:13",
    "tags": ["force", "encouragement"]
  },
  {
    "id": "fr-012",
    "text": "Car la joie de l'Éternel sera votre force.",
    "ref": "Néhémie 8:10",
    "tags": ["joie", "force"]
  },
  {
    "id": "fr-013",
    "text": "Tout est possible à celui qui croit.",
    "ref": "Marc 9:23",
    "tags": ["foi", "confiance"]
  },
  {
    "id": "fr-014",
    "text": "Je te loue de ce que je suis une créature si merveilleuse.",
    "ref": "Psaumes 139:14",
    "tags": ["louange", "encouragement"]
  },
  {
    "id": "fr-015",
    "text": "Que toute vallée soit comblée.",
    "ref": "Ésaïe 40:4",
    "tags": ["espoir"]
  },
  {
    "id": "fr-016",
    "text": "Le salut vient de l'Éternel.",
    "ref": "Jonas 2:9",
    "tags": ["salut", "confiance"]
  },
  {
    "id": "fr-017",
    "text": "Entrez dans ses portes avec des louanges.",
    "ref": "Psaumes 100:4",
    "tags": ["reconnaissance", "joie"]
  },
  {
    "id": "fr-018",
    "text": "Garde ton cœur plus que toute autre chose.",
    "ref": "Proverbes 4:23",
    "tags": ["sagesse"]
  },
  {
    "id": "fr-019",
    "text": "Autrefois vous étiez ténèbres, et maintenant vous êtes lumière dans le Seigneur.",
    "ref": "Éphésiens 5:8",
    "tags": ["lumière", "encouragement"]
  }
]